{{ if eq .Section "posts" }}<script>
(function(){
  var pc = document.getElementById('pc');
  if(!pc) return;
  if(window.innerWidth<768 && window.matchMedia('(orientation:portrait)').matches) return;

  var origHTML = pc.innerHTML;
  var vh = pc.clientHeight;
  var vw = pc.clientWidth;
  var fz = window.innerWidth < 768 ? 16 : 18;
  
  var m = document.createElement('div');
  m.style.cssText = 'writing-mode:vertical-rl;font-family:Noto Serif SC,serif;font-size:'+fz+'px;line-height:2;position:absolute;left:-9999px;height:'+vh+'px';
  m.innerHTML = origHTML;
  document.body.appendChild(m);
  
  var test = document.createElement('span');
  test.textContent = 'M';
  test.style.cssText = 'display:inline-block';
  m.appendChild(test);
  var colW = test.getBoundingClientRect().width;
  test.remove();
  
  var totalSW = m.scrollWidth;
  m.remove();
  
  var colsPerPage = Math.max(1, Math.floor(vw / colW));
  var pageW = colsPerPage * colW;
  var totalPages = Math.ceil(totalSW / pageW);
  
  if(totalPages <= 1) return;
  
  pc.style.position = 'relative';
  pc.style.touchAction = 'none';
  pc.innerHTML = '';
  
  var content = document.createElement('div');
  content.style.cssText = 'writing-mode:vertical-rl;font-family:Noto Serif SC,serif;font-size:'+fz+'px;line-height:2;height:'+vh+'px;position:absolute;top:0;right:0;transition:right 0.3s ease';
  content.innerHTML = origHTML;
  pc.appendChild(content);
  
  var pi=document.getElementById('pi'),pp=document.getElementById('pp'),pn=document.getElementById('pn');
  var cur=0;
  function show(n){
    cur=n;
    content.style.right = (-n * pageW) + 'px';
    pi.textContent=(cur+1)+'/'+totalPages;
    pp.style.opacity=cur===0?'0.3':'1';
    pn.style.opacity=cur>=totalPages-1?'0.3':'1';
  }
  window.fp=function(d){var n=cur+d;if(n>=0&&n<totalPages)show(n);};
  show(0);
  
  var sx=0,sy=0;
  pc.addEventListener('touchstart',function(e){sx=e.touches[0].clientX;sy=e.touches[0].clientY;});
  pc.addEventListener('touchend',function(e){
    var dx=sx-e.changedTouches[0].clientX;
    var dy=Math.abs(sy-e.changedTouches[0].clientY);
    if(dy>Math.abs(dx)*1.5) return;
    if(Math.abs(dx)>30) fp(dx<0?1:-1);
  });
  document.addEventListener('keydown',function(e){
    if(e.key==='ArrowRight') fp(1);
    else if(e.key==='ArrowLeft') fp(-1);
  });
})();
</script>{{ end }}